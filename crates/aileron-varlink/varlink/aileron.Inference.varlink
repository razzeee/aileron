# aileron.Inference — Foundation Models-style inference sessions

interface aileron.Inference

type ModelAvailability (
  is_available: bool,
  code: string,
  reason: string
)

type ResponseOptions (
  maximum_response_tokens: int,
  temperature: float,
  source_language_hint: string,
  target_language_hint: string,
  execution_mode: string
)

type GuidedOptions (
  maximum_response_tokens: int,
  temperature: float,
  execution_mode: string
)

type EmbedOptions (
  execution_mode: string
)

type SpeechOptions (
  source_language_hint: string,
  execution_mode: string
)

type VisionOptions (
  execution_mode: string
)

type GuidedField (
  name: string,
  kind: string,
  description: string,
  required: bool
)

type ToolDefinition (
  name: string,
  description: string,
  schema_json: string
)

type ToolCall (
  id: string,
  name: string,
  arguments_json: string
)

type ToolResult (
  id: string,
  content: string,
  content_json: string
)

type VisionSegment (
  label: string,
  confidence: float,
  x: float,
  y: float,
  width: float,
  height: float
)

# Return whether a profile is assigned and runnable for this use-case.
method GetUseCaseAvailability(app_id: string, use_case: string) -> (availability: ModelAvailability)

# Create an inference session with stable system instructions.
method CreateSession(app_id: string, use_case: string, instructions: string) -> (session_id: string, profile_id: string)

# Start the backing container before the first user-visible response.
method Prewarm(session_id: string) -> ()

# Stream response tokens. Session must have been created with a language generation use_case.
# input_json is either content-part shorthand or a role-message array. media_paths contains readable request-scoped media paths referenced by fd_index.
method StreamResponse(session_id: string, input_json: string, media_paths: []string, options: ResponseOptions) -> (token: string)

# Stream schema-valid guided output snapshots. The final reply has continues=false.
# prompt is plain text or content-part/role-message JSON. media_paths contains readable request-scoped media paths referenced by fd_index.
method StreamRespondGuided(session_id: string, prompt: string, media_paths: []string, fields: []GuidedField, tools: []ToolDefinition, options: GuidedOptions) -> (snapshot_json: string, tool_calls: []ToolCall)

# Stream guided generation after the app executes or rejects requested tools.
method StreamSubmitToolResultsGuided(session_id: string, prompt: string, media_paths: []string, results: []ToolResult, fields: []GuidedField, tools: []ToolDefinition, options: GuidedOptions) -> (snapshot_json: string, tool_calls: []ToolCall)

# Stream embedding vectors for text. Session must have been created with use_case: language.embed
# embedding: the embedding vector for the supplied text
method StreamEmbed(session_id: string, text: string, options: EmbedOptions) -> (embedding: []float)

# Stream transcript or translation segments. Session must have been created with
# use_case: speech.transcribe (verbatim, source language) or speech.translate (translated to English).
# audio_path: readable path for 16 kHz mono f32le PCM bytes
# The final reply has continues=false.
method StreamTranscribe(session_id: string, audio_path: string, options: SpeechOptions) -> (token: string)

# Stream image description tokens. Session must have been created with vision.describe
# image_path: readable path for PNG or JPEG bytes
# instructions: optional per-image instructions
method StreamDescribe(session_id: string, image_path: string, instructions: string, options: VisionOptions) -> (token: string)

# Stream OCR text tokens. Session must have been created with vision.ocr
# image_path: readable path for PNG or JPEG bytes
# instructions: optional per-image instructions
method StreamOcr(session_id: string, image_path: string, instructions: string, options: VisionOptions) -> (token: string)

# Stream identified objects in an image. Session must have been created with vision.segment
# Coordinates are normalized to 0.0..1.0, relative to the image dimensions.
# image_path: readable path for PNG or JPEG bytes
# instructions: optional per-image instructions
method StreamSegment(session_id: string, image_path: string, instructions: string, options: VisionOptions) -> (segments: []VisionSegment)

# End a session. The per-profile container remains pooled until idle timeout.
method EndSession(session_id: string) -> ()

error PermissionPromptRequired(app_id: string, use_case: string)
error PermissionDenied(app_id: string, use_case: string)
error SessionNotFound(session_id: string)
error ModelUnavailable(reason: string)
error InvalidGenerationOptions(reason: string)
error GuidedGenerationFailed(reason: string)
error GenerationFailed(reason: string)
error ContextWindowExceeded(reason: string)
error UnsupportedLanguage(reason: string)
error SafetyRefusal(reason: string)
error RequestCancelled(reason: string)
error InvalidInput(reason: string)
