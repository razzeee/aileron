# aileron.Inference — Foundation Models-style inference sessions

interface aileron.Inference

type ModelAvailability (
  is_available: bool,
  reason: string
)

type GenerationOptions (
  maximum_response_tokens: int,
  temperature: float,
  sampling_mode: string,
  source_language_hint: string,
  target_language_hint: string
)

type ChatMessage (
  role: string,
  content: string
)

type GuidedField (
  name: string,
  kind: string,
  description: string,
  required: bool
)

type VisionSegment (
  label: string,
  confidence: float,
  x: float,
  y: float,
  width: float,
  height: float
)

# Return whether a profile is assigned and runnable for this use-case.
method GetUseCaseAvailability(app_id: string, use_case: string) -> (availability: ModelAvailability)

# Create an inference session with stable system instructions.
method CreateSession(app_id: string, use_case: string, instructions: string) -> (session_id: string)

# Start the backing container before the first user-visible response.
method Prewarm(session_id: string, prompt_prefix: string) -> ()

# Generate a complete response. Session must have been created with an llm.* use_case.
method Respond(session_id: string, prompt: string, options: GenerationOptions) -> (content: string)

# Stream response tokens. Session must have been created with an llm.* use_case.
method StreamResponse(session_id: string, prompt: string, options: GenerationOptions) -> (token: string)

# Generate a chat response from explicit conversation messages. Session must use llm.chat.
method Chat(session_id: string, messages: []ChatMessage, options: GenerationOptions) -> (content: string)

# Stream chat response tokens from explicit conversation messages. Session must use llm.chat.
method StreamChat(session_id: string, messages: []ChatMessage, options: GenerationOptions) -> (token: string)

# Generate JSON matching field guides converted to a JSON Schema object.
# Session must have been created with an llm.* use_case.
method RespondGuided(session_id: string, prompt: string, fields: []GuidedField, options: GenerationOptions) -> (content: string)

# Compute embedding vectors for text. Session must have been created with use_case: llm.embed
# embedding: the embedding vector for the supplied text
method Embed(session_id: string, text: string) -> (embedding: []float)

# Transcribe or translate audio. Session must have been created with
# use_case: asr.transcribe (verbatim, source language) or asr.translate (translated to English).
# audio: raw PCM bytes encoded as base64 (16kHz mono f32le)
# language_hint: optional language hint; empty string means auto-detect/no hint
method Transcribe(session_id: string, audio: string, language_hint: string) -> (text: string)

# Describe an image. Session must have been created with vision.describe
# image: PNG or JPEG bytes encoded as base64
method Describe(session_id: string, image: string) -> (text: string)

# Extract text from an image (OCR). Session must have been created with vision.ocr
# image: PNG or JPEG bytes encoded as base64
method Ocr(session_id: string, image: string) -> (text: string)

# Identify objects in an image. Session must have been created with vision.segment
# Coordinates are normalized to 0.0..1.0, relative to the image dimensions.
# image: PNG or JPEG bytes encoded as base64
method Segment(session_id: string, image: string) -> (segments: []VisionSegment)

# End a session. The per-profile container remains pooled until idle timeout.
method EndSession(session_id: string) -> ()

error PermissionDenied(app_id: string, use_case: string)
error SessionNotFound(session_id: string)
error ModelUnavailable(reason: string)
error InvalidGenerationOptions(reason: string)
error GuidedGenerationFailed(reason: string)
error GenerationFailed(reason: string)
