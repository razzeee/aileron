FROM python:3.12-slim

# Vulkan build of llama-cpp-python.
# Works with any GPU that has Vulkan support: NVIDIA, AMD (without ROCm),
# Intel Arc, and most integrated graphics.
# The entrypoint auto-detects the GPU at runtime via vulkaninfo.

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build \
        libvulkan-dev vulkan-tools \
        libvulkan1 mesa-vulkan-drivers \
    && rm -rf /var/lib/apt/lists/*

ENV CMAKE_ARGS="-DLLAMA_VULKAN=on"

RUN pip install --no-cache-dir \
    "llama-cpp-python>=0.2.90" \
    jsonschema

COPY download_model.py /download_model.py

ARG MODEL_URL=""
RUN if [ -n "$MODEL_URL" ]; then \
        python /download_model.py "$MODEL_URL"; \
    else \
        mkdir -p /model; \
    fi

COPY entrypoint.py /entrypoint.py

LABEL aileron.use_cases="llm.summarize,llm.translate,llm.rephrase,llm.classify,llm.extract"

ENTRYPOINT ["python", "/entrypoint.py"]
