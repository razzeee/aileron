FROM rocm/dev-ubuntu-22.04:7.2.4-complete

# AMD ROCm build of llama-cpp-python.
# Requires ROCm drivers on the host and --device=/dev/kfd --device=/dev/dri at runtime
# (the daemon adds these automatically when ROCm is detected).
# The entrypoint auto-detects the GPU at runtime via rocm-smi.

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-pip python3-dev \
        build-essential cmake ninja-build \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf python3 /usr/bin/python

ARG AMDGPU_TARGETS="gfx1030"
ENV CMAKE_ARGS="-DGGML_HIP=on -DAMDGPU_TARGETS=${AMDGPU_TARGETS}"
ENV FORCE_CMAKE=1
ENV HSA_OVERRIDE_GFX_VERSION=10.3.0
ENV ROCM_PATH=/opt/rocm
ENV PATH="${ROCM_PATH}/bin:${PATH}"

RUN pip install --no-cache-dir \
    --no-binary llama-cpp-python \
    "llama-cpp-python>=0.2.90" \
    jsonschema

COPY download_model.py /download_model.py

ARG MODEL_URL=""
RUN if [ -n "$MODEL_URL" ]; then \
        python /download_model.py "$MODEL_URL"; \
    else \
        mkdir -p /model; \
    fi

COPY entrypoint.py /entrypoint.py

LABEL aileron.use_cases="llm.summarize,llm.translate,llm.rephrase,llm.classify,llm.extract"

ENTRYPOINT ["python", "/entrypoint.py"]
