[Unit]
Description=Aileron xdg-desktop-portal backend
Documentation=https://github.com/aileron-project/aileron
After=graphical-session.target aileron-daemon.service
BindsTo=aileron-daemon.service

[Service]
Type=dbus
BusName=org.freedesktop.impl.portal.desktop.aileron
ExecStart=%h/.local/bin/aileron-portal
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
